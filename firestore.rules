rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Phase 3: Primitive Definitions
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isAdmin() {
      return isSignedIn() && (
        (isEmailVerified() && exists(/databases/$(database)/documents/admins/$(request.auth.uid))) ||
        request.auth.token.email == "femizydasilver@gmail.com" ||
        request.auth.token.email == "lovethbproperties02@gmail.com" ||
        request.auth.token.email == "lovethproperties02@gmail.com" ||
        request.auth.token.email == "lovethpropertise02@gmail.com"
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Pillar 2: Validation Blueprints
    function isValidProperty(data) {
      return data.keys().hasAll(['title', 'description', 'price', 'location', 'category', 'status', 'imageUrls']) &&
             data.title is string && data.title.size() <= 200 &&
             data.description is string && data.description.size() <= 5000 &&
             data.price is number && data.price >= 0 &&
             data.location is string && data.location.size() <= 300 &&
             data.category in ['House', 'Land', 'Other'] &&
             data.status in ['For Sale', 'For Rent', 'Sold'] &&
             data.imageUrls is list && data.imageUrls.size() <= 20 &&
             (data.imageUrls.size() == 0 || data.imageUrls[0] is string) &&
             (!('featured' in data) || data.featured is bool) &&
             (!('size' in data) || (data.size is string && data.size.size() <= 100)) &&
             (!('amenities' in data) || (data.amenities is list && data.amenities.size() <= 50)) &&
             data.get('ownerId', request.auth.uid) == request.auth.uid;
    }

    function isValidInquiry(data) {
      return data.keys().hasAll(['name', 'email', 'phone', 'message', 'status', 'createdAt']) &&
             data.name is string && data.name.size() <= 100 &&
             data.email is string && data.email.size() <= 150 &&
             data.phone is string && data.phone.size() <= 20 &&
             data.message is string && data.message.size() <= 3000 &&
             data.status in ['New', 'Contacted', 'Closed'] &&
             data.createdAt == request.time;
    }

    // Match Blocks
    
    // Admins Collection
    match /admins/{adminId} {
      allow read: if isSignedIn();
      allow write: if isAdmin(); // Only existing admins or the bootstrap admin can add new admins
    }

    // Properties Collection
    match /properties/{propertyId} {
      allow get: if isValidId(propertyId);
      allow list: if true; // Public listings are visible to all
      
      allow create: if true;
      allow update: if true;
      allow delete: if true;
    }

    // Inquiries Collection
    match /inquiries/{inquiryId} {
      allow get: if true;
      allow list: if true;
      
      allow create: if isValidInquiry(incoming());
      allow update: if true;
      allow delete: if true;
    }
  }
}
